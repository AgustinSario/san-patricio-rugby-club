@model SanPatricioRugby.DAL.Models.Cuota

@{
    ViewData["Title"] = "Eliminar Cuota";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 text-center p-5">
            <div class="mx-auto text-danger mb-4">
                <i class="fa-solid fa-file-circle-minus display-1 opacity-25"></i>
            </div>
            
            <h2 class="fw-bold text-dark mb-2">¿Eliminar esta cuota?</h2>
            <p class="text-muted mb-5 fs-5">Estás por borrar el registro de cuota del período <strong>@Model.Mes/@Model.Anio</strong> para el socio <strong>@Model.Socio?.ApellidoNombre</strong>.</p>

            <div class="bg-light p-4 rounded-3 border-start border-4 border-danger text-start mb-5">
                <div class="mb-2">
                    <small class="text-muted">Importe registrado:</small>
                    <p class="fw-bold fs-5 mb-0">$ @Model.Monto.ToString("N0")</p>
                </div>
                <div>
                    <small class="text-muted">Estado Actual:</small>
                    <p class="fw-bold fs-5 mb-0 text-danger">@Model.Estado</p>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a asp-action="Index" class="btn btn-light px-5 py-3 fw-bold border shadow-sm w-100 w-sm-auto me-sm-2">Cancelar</a>
                    <button type="submit" class="btn btn-danger px-5 py-3 fw-bold shadow w-100 w-sm-auto">Confirmar Eliminación</button>
                </div>
            </form>
        </div>
    </div>
</div>

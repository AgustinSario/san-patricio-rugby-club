@model SanPatricioRugby.Web.Models.PaginatedList<SanPatricioRugby.DAL.Models.Cuota>
@using SanPatricioRugby.DAL.Models

@{
    ViewData["Title"] = "Historial de Cuotas";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h3 mb-1 fw-bold text-dark">Pagos y Cuotas</h1>
            <p class="text-muted mb-0">Listado general de cuotas generadas y estados de cobro.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="fa-solid fa-plus me-2"></i> Generar Cuota</a>
        </div>
    </div>
</div>

<!-- Search Section -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-9">
                <label class="form-label fw-semibold text-muted small">Buscar por Nombre de Socio</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 bg-light shadow-none" placeholder="Ingresa nombre del socio..." />
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4 w-100 fw-bold">Buscar</button>
                <a asp-action="Index" class="btn btn-light border px-3" title="Limpiar filtros">
                    <i class="fa-solid fa-rotate-left"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light shadow-sm">
                    <tr>
                        <th class="ps-4">Socio</th>
                        <th>Periodo</th>
                        <th>Importe</th>
                        <th>Vencimiento</th>
                        <th>Estado</th>
                        <th>Medio / Fecha Pago</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4">
                            <a asp-controller="Socios" asp-action="Details" asp-route-id="@item.SocioId" class="text-dark fw-bold text-decoration-none hover-primary">
                                @item.Socio?.ApellidoNombre
                            </a>
                        </td>
                        <td class="fw-medium text-muted">@item.Mes.ToString("00") / @item.Anio</td>
                        <td class="fw-bold fs-6 text-dark">$ @item.Monto.ToString("N0")</td>
                        <td class="small">@item.FechaVencimiento.ToShortDateString()</td>
                        <td>
                            @switch (item.Estado) {
                                case EstadoPago.Pagado:
                                    <span class="badge bg-success bg-opacity-10 text-success border-0 px-3 py-2 rounded-pill"><i class="fa-solid fa-circle-check me-2"></i>Pagado</span>
                                    break;
                                case EstadoPago.Vencido:
                                    <span class="badge bg-danger bg-opacity-10 text-danger border-0 px-3 py-2 rounded-pill"><i class="fa-solid fa-clock me-2"></i>Vencido</span>
                                    break;
                                default:
                                    <span class="badge bg-warning bg-opacity-10 text-warning border-0 px-3 py-2 rounded-pill"><i class="fa-solid fa-hourglass-half me-2"></i>Pendiente</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (item.Estado == EstadoPago.Pagado) {
                                <div class="small">
                                    <span class="d-block text-dark fw-medium">@item.MedioPagoUtilizado</span>
                                    <span class="text-muted">@item.FechaPago?.ToShortDateString()</span>
                                </div>
                            } else {
                                <span class="text-muted small">---</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border" title="Editar cuota">
                                    <i class="fa-solid fa-pen text-warning"></i>
                                </a>
                                @if (item.Estado != EstadoPago.Pagado) {
                                    <button class="btn btn-sm btn-success border" onclick="marcarPagado(@item.Id)"><i class="fa-solid fa-cash-register me-1"></i> Cobrar</button>
                                }
                            </div>
                        </td>
                    </tr>
                    }
                    @if (!Model.Any()) {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                No se encontraron cuotas que coincidan con la búsqueda.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- Pagination Section -->
    @if (Model.TotalPages > 1) {
        <div class="card-footer bg-white py-3 border-top d-flex justify-content-between align-items-center px-4">
            <p class="text-muted mb-0 small">Página @Model.PageIndex de @Model.TotalPages</p>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" 
                           asp-route-pageNumber="@(Model.PageIndex - 1)" 
                           asp-route-searchString="@ViewData["CurrentFilter"]">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                    </li>
                    
                    @for (int i = 1; i <= Model.TotalPages; i++) {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index" 
                               asp-route-pageNumber="@i"
                               asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" asp-action="Index" 
                           asp-route-pageNumber="@(Model.PageIndex + 1)"
                           asp-route-searchString="@ViewData["CurrentFilter"]">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function marcarPagado(id) {
            Swal.fire({
                title: 'Confirmar Cobro',
                text: "¿Cómo abonó el socio esta cuota?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#0d6efd',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<i class="fa-solid fa-cash-register me-1"></i> Registrar Pago',
                cancelButtonText: 'Cancelar',
                input: 'select',
                inputOptions: {
                    '1': 'Efectivo',
                    '2': 'Débito',
                    '3': 'Transferencia',
                    '4': 'Tarjeta Crédito'
                },
                inputPlaceholder: 'Seleccione medio de pago...',
                inputValidator: (value) => {
                    return new Promise((resolve) => {
                        if (value) resolve();
                        else resolve('Debes seleccionar un medio de pago');
                    });
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    registrarPago(id, result.value, null);
                }
            });
        }

        function registrarPago(id, medio, emailSocio) {
            const data = new FormData();
            data.append('id', id);
            data.append('medio', medio);
            if (emailSocio) data.append('emailSocio', emailSocio);

            // Token antiforgery no requerido en este endpoint (es HttpPost sin [ValidateAntiForgeryToken])
            fetch('/Cuotas/Pagar', {
                method: 'POST',
                body: data
            })
            .then(r => r.json())
            .then(resp => {
                if (!resp.ok) {
                    Swal.fire('Error', 'No se pudo registrar el pago.', 'error');
                    return;
                }

                if (resp.necesitaEmail) {
                    // El socio no tiene email → pedirlo una única vez
                    Swal.fire({
                        title: '📧 Email del Socio',
                        html: `<p style="font-size:14px;color:#555">El pago fue registrado exitosamente.<br><br>
                                ¿Querés enviarle el recibo por email?<br>
                                <small class="text-muted">El email quedará guardado para futuros cobros.</small></p>`,
                        input: 'email',
                        inputPlaceholder: 'correo@ejemplo.com',
                        showCancelButton: true,
                        denyButtonColor: '#0d6efd',
                        confirmButtonText: '<i class="fa-solid fa-paper-plane me-1"></i> Enviar Recibo',
                        cancelButtonText: 'Omitir',
                        denyButtonText: '<i class="fa-solid fa-eye me-1"></i> Vista Previa',
                        inputValidator: (value) => {
                            var emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                            if (value && !emailRegex.test(value)) {
                                return 'Ingresá un email válido';
                            }
                        }
                    }).then(emailResult => {
                        if (emailResult.isConfirmed && emailResult.value) {
                            // Re-enviar con el email capturado (pago ya registrado, solo envía email)
                            enviarSoloEmail(id, emailResult.value);
                        } else if (emailResult.isDenied) {
                            // Vista previa y luego volver a preguntar? 
                            // Mejor abrir en nueva pestaña y no cerrar el flujo
                            window.open('/Cuotas/DescargarRecibo/' + id, '_blank');
                            // Re-lanzar este mismo modal para que el usuario pueda seguir el flujo
                            registrarPago(id, medio, emailSocio); 
                        } else {
                            mostrarExito('¡Pago registrado! No se envió el recibo.', false, id);
                        }
                    });
                } else if (resp.emailEnviado) {
                    mostrarExito('¡Pago registrado y recibo enviado por email!', true, id);
                } else if (resp.warning) {
                    Swal.fire({
                        icon: 'warning',
                        title: '¡Pago registrado!',
                        text: resp.warning,
                        confirmButtonColor: '#0d6efd',
                        showDenyButton: true,
                        denyButtonText: '<i class="fa-solid fa-eye me-1"></i> Ver Recibo',
                        denyButtonColor: '#0d6efd'
                    }).then((wResult) => {
                        if (wResult.isDenied) {
                            window.open('/Cuotas/DescargarRecibo/' + id, '_blank');
                        }
                        location.reload();
                    });
                } else {
                    mostrarExito('¡Pago registrado!', false, id);
                }
            })
            .catch(() => {
                Swal.fire('Error', 'No se pudo conectar con el servidor.', 'error');
            });
        }

        function enviarSoloEmail(cuotaId, email) {
            const data = new FormData();
            data.append('cuotaId', cuotaId);
            data.append('email', email);

            fetch('/Cuotas/EnviarReciboEmail', {
                method: 'POST',
                body: data
            })
            .then(r => r.json())
            .then(resp => {
                if (resp.enviado) {
                    mostrarExito('¡Pago registrado y recibo enviado por email!', true, cuotaId);
                } else {
                    Swal.fire({ 
                        icon: 'warning', 
                        title: '¡Pago registrado!', 
                        text: 'No se pudo enviar el recibo: ' + (resp.error || ''), 
                        confirmButtonColor: '#0d6efd',
                        showDenyButton: true,
                        denyButtonText: '<i class="fa-solid fa-eye me-1"></i> Ver Recibo',
                        denyButtonColor: '#0d6efd'
                    }).then((res) => {
                        if (res.isDenied) window.open('/Cuotas/DescargarRecibo/' + cuotaId, '_blank');
                        location.reload();
                    });
                }
            });
        }

        function mostrarExito(mensaje, conEmail, id) {
            Swal.fire({
                icon: 'success',
                title: '¡Operación Exitosa!',
                text: mensaje,
                showDenyButton: true,
                confirmButtonColor: '#198754',
                denyButtonColor: '#0d6efd',
                confirmButtonText: 'Aceptar',
                denyButtonText: '<i class="fa-solid fa-eye me-1"></i> Ver Recibo',
            }).then((result) => {
                if (result.isDenied) {
                    window.open('/Cuotas/DescargarRecibo/' + id, '_blank');
                    // No recargamos aquí para que pueda volver y enviar email si así lo desea, 
                    // o mostramos un botón para cerrar y recargar
                    Swal.fire({
                        title: 'Aviso',
                        text: 'El recibo se abrió en una nueva pestaña.',
                        icon: 'info',
                        confirmButtonText: 'Cerrar y Actualizar'
                    }).then(() => location.reload());
                } else {
                    location.reload();
                }
            });
        }
    </script>
}

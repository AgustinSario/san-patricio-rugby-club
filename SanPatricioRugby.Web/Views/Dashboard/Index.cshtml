@model IEnumerable<SanPatricioRugby.DAL.Models.Cuota>
@{
    ViewData["Title"] = "Panel Principal";
    var totalActivos = (int)ViewBag.SociosActivos;
    var totalAlDia = (int)ViewBag.SociosAlDia;
    var porcentaje = totalActivos > 0 ? (int)Math.Round(((double)totalAlDia / totalActivos) * 100) : 0;
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="fw-bold text-dark mb-0">Resumen del Club</h2>
        <p class="text-muted mb-0">Indicadores principales de la gestión de socios de San Patricio Rugby</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <button class="btn btn-primary bg-primary-color border-0">
            <i class="fa-solid fa-download me-2"></i> Exportar Reporte
        </button>
    </div>
</div>

<div class="row g-4">
    <!-- Socios Activos Card -->
    <div class="col-md-4">
        <div class="card card-premium kpi-card">
            <div>
                <h6 class="kpi-title">Socios Activos (Total)</h6>
                <p class="kpi-value kpi-active">@totalActivos</p>
            </div>
            <div class="mt-4">
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">
                    <i class="fa-solid fa-users me-1"></i> Base Social
                </span>
            </div>
            <i class="fa-solid fa-users kpi-icon"></i>
        </div>
    </div>

    <!-- Socios al Día Card -->
    <div class="col-md-4">
        <div class="card card-premium kpi-card">
            <div>
                <h6 class="kpi-title">Socios al Día</h6>
                <p class="kpi-value kpi-current">@totalAlDia</p>
            </div>
            <div class="mt-4">
                <div class="progress" style="height: 6px;">
                  <div class="progress-bar bg-primary" role="progressbar" style="width: @porcentaje%;" aria-valuenow="@porcentaje" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <small class="text-muted mt-2 d-block">@porcentaje% del total activo</small>
            </div>
            <i class="fa-solid fa-circle-check kpi-icon"></i>
        </div>
    </div>

    <!-- Socios Morosos Card -->
    <div class="col-md-4">
        <div class="card card-premium kpi-card">
            <div>
                <h6 class="kpi-title">Socios Morosos</h6>
                <p class="kpi-value kpi-debt">@ViewBag.SociosMorosos</p>
            </div>
            <div class="mt-4">
                @if ((int)ViewBag.SociosMorosos > 0) {
                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2">
                        <i class="fa-solid fa-circle-exclamation me-1"></i> Requiere atención
                    </span>
                } else {
                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">
                        <i class="fa-solid fa-check me-1"></i> Cartera Saneada
                    </span>
                }
            </div>
            <i class="fa-solid fa-triangle-exclamation kpi-icon"></i>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12">
        <div class="card card-premium">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold mb-0">Últimos Pagos Registrados</h5>
            </div>
            <div class="card-body p-0 mt-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4 border-0">Socio</th>
                                <th class="border-0">Período</th>
                                <th class="border-0">Fecha Pago</th>
                                <th class="border-0">Monto</th>
                                <th class="pe-4 border-0 text-end">Medio</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any()) {
                                @foreach (var pago in Model) {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px; font-weight: 600; font-size: 0.8rem;">
                                                    @pago.Socio?.ApellidoNombre.Substring(0, 1).ToUpper()
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fw-medium small">@pago.Socio?.ApellidoNombre</h6>
                                                    <small class="text-muted">ID: #@pago.Socio?.NumeroIdentificador</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="small fw-medium">@pago.Mes/@pago.Anio</td>
                                        <td class="small">@pago.FechaPago?.ToShortDateString()</td>
                                        <td class="fw-bold text-dark">$@pago.Monto.ToString("N0")</td>
                                        <td class="pe-4 text-end">
                                            <span class="badge bg-success bg-opacity-10 text-success border-0 px-2 py-1">
                                                @pago.MedioPagoUtilizado
                                            </span>
                                        </td>
                                    </tr>
                                }
                            } else {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        No hay pagos registrados recientemente.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white border-top-0 py-3 text-center">
                <a asp-controller="Cuotas" asp-action="Index" class="text-decoration-none text-primary-color fw-medium">Ver todos los movimientos <i class="fa-solid fa-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>
</div>

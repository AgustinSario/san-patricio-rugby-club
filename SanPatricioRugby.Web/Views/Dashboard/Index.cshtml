@model IEnumerable<SanPatricioRugby.DAL.Models.Socio>
@{
    ViewData["Title"] = "Panel Principal";
    var totalActivos = (int)ViewBag.SociosActivos;
    var totalAlDia = (int)ViewBag.SociosAlDia;
    var porcentaje = totalActivos > 0 ? (int)Math.Round(((double)totalAlDia / totalActivos) * 100) : 0;
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="fw-bold text-dark mb-0">Resumen del Club</h2>
        <p class="text-muted mb-0">Indicadores principales de la gestión de socios de San Patricio Rugby</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <button class="btn btn-primary bg-primary-color border-0">
            <i class="fa-solid fa-download me-2"></i> Exportar Reporte
        </button>
    </div>
</div>

<div class="row g-4">
    <!-- Socios Activos Card -->
    <div class="col-md-4">
        <div class="card card-premium kpi-card">
            <div>
                <h6 class="kpi-title">Socios Activos (Total)</h6>
                <p class="kpi-value kpi-active">@totalActivos</p>
            </div>
            <div class="mt-4">
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">
                    <i class="fa-solid fa-users me-1"></i> Base Social
                </span>
            </div>
            <i class="fa-solid fa-users kpi-icon"></i>
        </div>
    </div>

    <!-- Socios al Día Card -->
    <div class="col-md-4">
        <div class="card card-premium kpi-card">
            <div>
                <h6 class="kpi-title">Socios al Día</h6>
                <p class="kpi-value kpi-current">@totalAlDia</p>
            </div>
            <div class="mt-4">
                <div class="progress" style="height: 6px;">
                  <div class="progress-bar bg-primary" role="progressbar" style="width: @porcentaje%;" aria-valuenow="@porcentaje" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <small class="text-muted mt-2 d-block">@porcentaje% del total activo</small>
            </div>
            <i class="fa-solid fa-circle-check kpi-icon"></i>
        </div>
    </div>

    <!-- Socios Morosos Card -->
    <div class="col-md-4">
        <a asp-controller="Socios" asp-action="SocioMorosos" class="text-decoration-none card-link-hover">
            <div class="card card-premium kpi-card-clickable h-100">
                <div>
                    <h6 class="kpi-title text-muted">Socios Morosos</h6>
                    <p class="kpi-value text-danger">@ViewBag.SociosMorosos</p>
                </div>
                <div class="mt-4">
                    @if ((int)ViewBag.SociosMorosos > 0) {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2">
                            <i class="fa-solid fa-circle-exclamation me-1"></i> Requiere atención
                        </span>
                    } else {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2">
                            <i class="fa-solid fa-check me-1"></i> Cartera Saneada
                        </span>
                    }
                </div>
                <i class="fa-solid fa-triangle-exclamation icon-bg-danger"></i>
            </div>
        </a>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12">
        <div class="card card-premium">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold mb-0">Listado de Socios Becados</h5>
                <p class="text-muted small mt-1 mb-0">Total: @Model.Count() socios con beneficios de beca activos</p>
            </div>
            <div class="card-body p-0 mt-3">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted small text-uppercase">
                            <tr>
                                <th class="ps-4 border-0">Socio</th>
                                <th class="border-0">DNI</th>
                                <th class="border-0">Tipo de Socio</th>
                                <th class="border-0">Acuerdos / Beca</th>
                                <th class="pe-4 border-0 text-end">División</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any()) {
                                @foreach (var socio in Model) {
                                    <tr>
                                        <td class="ps-4">
                                            <a asp-controller="Socios" asp-action="Details" asp-route-id="@socio.Id" class="text-decoration-none text-dark">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 35px; height: 35px; font-weight: 600; font-size: 0.8rem;">
                                                        @socio.ApellidoNombre.Substring(0, 1).ToUpper()
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0 fw-medium small">@socio.ApellidoNombre</h6>
                                                        <small class="text-muted">ID: @socio.NumeroIdentificador</small>
                                                    </div>
                                                </div>
                                            </a>
                                        </td>
                                        <td class="small">@(socio.Dni ?? "-")</td>
                                        <td class="small">
                                            <span class="badge bg-primary bg-opacity-10 text-primary border-0 px-2 py-1">
                                                @socio.TipoSocio
                                            </span>
                                        </td>
                                        <td class="small text-muted text-truncate" style="max-width: 250px;">
                                            @socio.Acuerdos
                                        </td>
                                        <td class="pe-4 text-end small fw-medium text-dark">
                                            @socio.Division
                                        </td>
                                    </tr>
                                }
                            } else {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        No se registran socios con becas activas en la base de datos.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white border-top-0 py-3 text-center">
                <a asp-controller="Socios" asp-action="Index" class="text-decoration-none text-primary-color fw-medium">Ver todos los socios <i class="fa-solid fa-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>
</div>

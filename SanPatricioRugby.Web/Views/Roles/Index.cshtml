@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityRole>

@{
    ViewData["Title"] = "Gestión de Roles";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="fw-bold text-dark mb-0">@ViewData["Title"]</h2>
        <p class="text-muted mb-0">Administra los permisos y acceso a módulos del sistema.</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <a asp-action="Create" class="btn btn-primary bg-primary-color border-0">
            <i class="fa-solid fa-plus me-2"></i> Crear Nuevo Rol
        </a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-premium mt-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="ps-4 border-0">Nombre del Rol (Permiso)</th>
                        <th class="pe-4 border-0 text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var role in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium text-dark">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm border" style="width: 36px; height: 36px;">
                                            <i class="fa-solid fa-shield-halved text-primary-color"></i>
                                        </div>
                                        @role.Name
                                        @if (role.Name == "Admin")
                                        {
                                            <span class="badge bg-danger ms-2">Sistema</span>
                                        }
                                    </div>
                                </td>
                                <td class="pe-4 text-end">
                                    @if (role.Name != "Admin")
                                    {
                                        <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="d-inline" onsubmit="return confirm('¿Está seguro de eliminar este rol? Considere que los usuarios podrían perder acceso a módulos.');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="fa-solid fa-trash-can"></i> Eliminar
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center py-4 text-muted">
                                No hay roles registrados todavía.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

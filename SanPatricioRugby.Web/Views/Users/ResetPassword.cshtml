@using SanPatricioRugby.Web.Models
@model ResetPasswordViewModel

@{
    ViewData["Title"] = "Forzar Nueva Contraseña";
}

<div class="row justify-content-center">
    <div class="col-md-6 mt-4">
        <div class="card card-premium border-danger border-opacity-25" style="border-top: 4px solid #cc0000 !important;">
            <div class="card-body p-5">
                <h4 class="card-title fw-bold text-dark mb-4 text-center">@ViewData["Title"]</h4>
                
                <p class="text-muted text-center mb-4">
                    Estás forzando una nueva contraseña para la cuenta:<br/>
                    <strong>@Model.Email</strong>
                </p>
                
                <form asp-action="ResetPassword" method="post">
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Email" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="NewPassword" class="form-label text-muted fw-medium d-flex justify-content-between">
                            Nueva Contraseña
                            <small class="text-danger"><i class="fa-solid fa-triangle-exclamation"></i> Requerida</small>
                        </label>
                        <input asp-for="NewPassword" class="form-control form-control-lg bg-light" required>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label text-muted fw-medium d-flex justify-content-between">
                            Confirmar Nueva Contraseña
                        </label>
                        <input asp-for="ConfirmPassword" class="form-control form-control-lg bg-light" required>
                    </div>

                    <div class="d-grid gap-2 mt-5">
                        <button type="submit" class="btn btn-danger btn-lg shadow-sm">
                            <i class="fa-solid fa-key me-2"></i>Aplicar Nueva Clave
                        </button>
                        <a asp-action="Index" class="btn btn-light text-muted">Cancelar y Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@using SanPatricioRugby.Web.Models
@model CreateUserViewModel

@{
    ViewData["Title"] = "Crear Nuevo Usuario";
}

<div class="row justify-content-center">
    <div class="col-md-8 mt-4">
        <div class="card card-premium">
            <div class="card-body p-5">
                <h4 class="card-title fw-bold text-dark mb-4 text-center">@ViewData["Title"]</h4>
                
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    
                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <label asp-for="Email" class="form-label text-muted fw-medium">Correo Electrónico</label>
                            <input asp-for="Email" class="form-control form-control-lg bg-light" placeholder="usuario@sanpatricio.com">
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6 mb-4">
                            <label asp-for="Password" class="form-label text-muted fw-medium">Contraseña Temporal</label>
                            <input asp-for="Password" class="form-control bg-light">
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label asp-for="ConfirmPassword" class="form-label text-muted fw-medium">Confirmar Contraseña</label>
                            <input asp-for="ConfirmPassword" class="form-control bg-light">
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4 mt-3">
                        <label class="form-label text-muted fw-medium d-block border-bottom pb-2">Roles Asignados (Módulos permitidos)</label>
                        <div class="row px-3 mt-3">
                            @if(Model.AvailableRoles != null && Model.AvailableRoles.Any())
                            {
                                foreach(var role in Model.AvailableRoles)
                                {
                                    <div class="col-md-4 mb-2">
                                        <div class="form-check form-switch cursor-pointer">
                                            <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@role" id="role_@role"
                                                   @(Model.SelectedRoles != null && Model.SelectedRoles.Contains(role) ? "checked" : "")>
                                            <label class="form-check-label" for="role_@role">@role</label>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted small">No hay roles creados en el sistema. Primero crea un <a asp-controller="Roles" asp-action="Index">Rol</a>.</p>
                            }
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-5">
                        <button type="submit" class="btn btn-primary bg-primary-color border-0 btn-lg shadow-sm">Registrar Usuario</button>
                        <a asp-action="Index" class="btn btn-light text-muted">Cancelar y Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

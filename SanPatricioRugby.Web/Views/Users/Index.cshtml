@using SanPatricioRugby.Web.Models
@model IEnumerable<UserViewModel>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="row mb-4 align-items-center">
    <div class="col-md-8">
        <h2 class="fw-bold text-dark mb-0">@ViewData["Title"]</h2>
        <p class="text-muted mb-0">Administra los accesos y permisos de los operadores del sistema</p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <a asp-action="Create" class="btn btn-primary bg-primary-color border-0">
            <i class="fa-solid fa-user-plus me-2"></i> Crear Usuario
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-premium mt-3">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="ps-4 border-0">Email / Usuario</th>
                        <th class="border-0">Roles Asignados (Permisos)</th>
                        <th class="pe-4 border-0 text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium text-dark">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm border" style="width: 36px; height: 36px;">
                                            <i class="fa-solid fa-user text-primary-color"></i>
                                        </div>
                                        @user.Email
                                    </div>
                                </td>
                                <td>
                                    @if (user.Roles.Any())
                                    {
                                        foreach (var role in user.Roles)
                                        {
                                            <span class="badge bg-secondary me-1 mb-1">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">Sin roles</span>
                                    }
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border dropdown-toggle" type="button" id="actionsDropdown-@user.Id" data-bs-toggle="dropdown" aria-expanded="false">
                                            Opciones
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="actionsDropdown-@user.Id">
                                            <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@user.Id"><i class="fa-solid fa-pen-to-square me-2 text-primary-color"></i> Editar Roles</a></li>
                                            <li><a class="dropdown-item" asp-action="ResetPassword" asp-route-id="@user.Id"><i class="fa-solid fa-key me-2 text-warning"></i> Resetear Clave</a></li>
                                            @if (user.Email != "admin@sanpatricio.com")
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" onsubmit="return confirm('¿Está seguro de eliminar a este usuario permanentemente?');">
                                                        <button type="submit" class="dropdown-item text-danger"><i class="fa-solid fa-trash-can me-2"></i> Eliminar</button>
                                                    </form>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">No hay usuarios registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

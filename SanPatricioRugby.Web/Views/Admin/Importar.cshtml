@{
    ViewData["Title"] = "Importación Mensual";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="display-4 text-primary mb-3">
                        <i class="fa-solid fa-file-excel"></i>
                    </div>
                    <h2 class="fw-bold">Importar Listado Mensual</h2>
                    <p class="text-muted">Sube el archivo Excel actualizado para sincronizar socios y cuotas de forma incremental.</p>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm mb-4" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-circle-check fs-4 me-3"></i>
                            <div>
                                <h6 class="alert-heading fw-bold mb-1">¡Éxito!</h6>
                                <p class="mb-0 text-dark" style="white-space: pre-line">@TempData["SuccessMessage"]</p>
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 shadow-sm mb-4"></div>

                <form asp-action="Importar" method="post" enctype="multipart/form-data" class="mt-4">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-4">
                        <label for="excelFile" class="form-label fw-semibold text-muted small">Archivo Excel (.xlsx)</label>
                        <div class="input-group">
                            <input type="file" name="excelFile" id="excelFile" class="form-control border-0 bg-light shadow-none py-3" accept=".xlsx" required />
                        </div>
                        <div class="form-text mt-2">
                            <i class="fa-solid fa-info-circle me-1"></i> Asegúrate de que el archivo contenga la hoja <strong>"LISTADO SOCIOS 2025 JAVIER "</strong>.
                        </div>
                    </div>

                    <div class="card bg-light border-0 rounded-3 mb-4">
                        <div class="card-body p-3">
                            <h6 class="fw-bold text-dark mb-2"><i class="fa-solid fa-gear me-2"></i>Lógica de Procesamiento:</h6>
                            <ul class="small text-muted mb-0 ps-3">
                                <li>Reconoce socios existentes por Nombre y DNI para evitar duplicados.</li>
                                <li>Actualiza datos de contacto y medio de pago automáticamente.</li>
                                <li>Sincroniza cuotas desde Enero 2025 a Febrero 2026.</li>
                                <li><strong>No sobrescribe</strong> pagos ya registrados manualmente.</li>
                            </ul>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm py-3" id="btnSubmit">
                            <i class="fa-solid fa-cloud-arrow-up me-2"></i> Iniciar Sincronización
                        </button>
                    </div>
                </form>

                <div class="text-center mt-4 pt-3">
                    <a asp-controller="Socios" asp-action="Index" class="text-decoration-none text-muted small">
                        <i class="fa-solid fa-arrow-left me-1"></i> Volver al Listado de Socios
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="loader" class="d-none position-fixed top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-flex flex-column align-items-center justify-content-center" style="z-index: 9999;">
    <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
        <span class="visually-hidden">Procesando...</span>
    </div>
    <h5 class="fw-bold text-dark">Sincronizando datos...</h5>
    <p class="text-muted">Esto puede tardar unos segundos, por favor no cierres la pestaña.</p>
</div>

@section Scripts {
    <script>
        document.querySelector('form').addEventListener('submit', function() {
            document.getElementById('btnSubmit').disabled = true;
            document.getElementById('loader').classList.remove('d-none');
        });
    </script>
}

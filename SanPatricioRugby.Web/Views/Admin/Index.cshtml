@{
    ViewData["Title"] = "Panel de Administración";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="h3 mb-1 fw-bold text-dark">
            <i class="fa-solid fa-gears me-2 text-primary"></i>
            Panel de Administración
        </h1>
        <p class="text-muted">Gestioná las configuraciones globales, importaciones y seguridad del sistema.</p>
    </div>
</div>

<div class="row g-4">
    <!-- Importación -->
    <div class="col-md-4">
        <a asp-controller="Admin" asp-action="Importar" class="text-decoration-none">
            <div class="card border-0 shadow-sm rounded-4 h-100 admin-card hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-success bg-opacity-10 p-4 d-inline-block mb-3">
                        <i class="fa-solid fa-file-import fs-1 text-success"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Importar Mensual</h5>
                    <p class="text-muted small mb-0">Sincronizá socios y cuotas desde archivos Excel mensuales.</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Configuración Email -->
    <div class="col-md-4">
        <a asp-controller="Admin" asp-action="ConfigEmail" class="text-decoration-none">
            <div class="card border-0 shadow-sm rounded-4 h-100 admin-card hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-4 d-inline-block mb-3">
                        <i class="fa-solid fa-envelope-circle-check fs-1 text-primary"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Configuración de Email</h5>
                    <p class="text-muted small mb-0">Configurá el servidor SMTP y los datos del club para los recibos.</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Configuración Precios -->
    <div class="col-md-4">
        <a asp-controller="Acceso" asp-action="Precios" class="text-decoration-none">
            <div class="card border-0 shadow-sm rounded-4 h-100 admin-card hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-4 d-inline-block mb-3">
                        <i class="fa-solid fa-coins fs-1 text-warning"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Configurar Precios</h5>
                    <p class="text-muted small mb-0">Gestioná los costos de acceso para no-socios y estacionamiento.</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Usuarios -->
    <div class="col-md-4">
        <a asp-controller="Users" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm rounded-4 h-100 admin-card hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-info bg-opacity-10 p-4 d-inline-block mb-3">
                        <i class="fa-solid fa-user-shield fs-1 text-info"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Gestión de Usuarios</h5>
                    <p class="text-muted small mb-0">Administrá las cuentas de operadores y gerentes.</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Roles -->
    <div class="col-md-4">
        <a asp-controller="Roles" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm rounded-4 h-100 admin-card hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="rounded-circle bg-secondary bg-opacity-10 p-4 d-inline-block mb-3">
                        <i class="fa-solid fa-tags fs-1 text-secondary"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Roles y Permisos</h5>
                    <p class="text-muted small mb-0">Definí los niveles de acceso y visibilidad de pantallas.</p>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
    .admin-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08) !important;
    }
</style>

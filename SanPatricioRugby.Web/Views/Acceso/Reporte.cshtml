@model SanPatricioRugby.Web.Services.RecaudacionDiaViewModel
@using SanPatricioRugby.DAL.Models

@{
    ViewData["Title"] = "Reporte de Partido";
    var fechaActual = Model.Fecha.ToString("yyyy-MM-dd");
}

<div class="container py-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h1 class="h3 fw-bold text-dark mb-1">Cierre de Caja / Reporte</h1>
            <p class="text-muted small mb-0">Resumen detallado de ingresos y estacionamiento</p>
        </div>
        <div class="col-md-6 mt-3 mt-md-0">
            <form asp-action="Reporte" method="get" class="row g-2 justify-content-md-end">
                <div class="col-auto">
                    <input type="date" name="fecha" value="@fechaActual" class="form-control border-0 shadow-sm rounded-pill px-4" onchange="this.form.submit()" />
                </div>
                <div class="col-auto">
                    <button type="button" onclick="window.print()" class="btn btn-outline-dark rounded-pill px-3 shadow-sm bg-white">
                        <i class="fa-solid fa-print"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Resumen de Totales -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-body p-3 text-center">
                    <div class="text-primary-color mb-1"><i class="fa-solid fa-money-bill-wave fs-4"></i></div>
                    <h6 class="text-muted small fw-bold mb-1">RECAUDACIÓN</h6>
                    <h4 class="fw-bold mb-0 text-dark">$ @((Model.TotalIngresos + Model.TotalEstacionamiento).ToString("N0"))</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white border-start border-4 border-warning">
                <div class="card-body p-3 text-center">
                    <div class="text-warning mb-1"><i class="fa-solid fa-users fs-4"></i></div>
                    <h6 class="text-muted small fw-bold mb-1">PERSONAS</h6>
                    <h4 class="fw-bold mb-0 text-dark">@Model.CantidadIngresos</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white border-start border-4 border-info">
                <div class="card-body p-3 text-center">
                    <div class="text-info mb-1"><i class="fa-solid fa-car fs-4"></i></div>
                    <h6 class="text-muted small fw-bold mb-1">VEHÍCULOS</h6>
                    <h4 class="fw-bold mb-0 text-dark">@Model.CantidadVehiculos</h4>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-dark text-white">
                <div class="card-body p-3 text-center">
                    <div class="text-light-site mb-1"><i class="fa-solid fa-calendar-day fs-4"></i></div>
                    <h6 class="text-muted small fw-bold mb-1">FECHA</h6>
                    <h4 class="fw-bold mb-0 text-white">@Model.Fecha.ToString("dd/MM")</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Desglose de Personas -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-0 d-flex align-items-center">
            <i class="fa-solid fa-id-card text-danger me-2"></i>
            <h5 class="mb-0 fw-bold h6">Detalle de Ingresos</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small">
                    <tr>
                        <th class="ps-4">Hora</th>
                        <th>Socio / Persona</th>
                        <th>Tipo</th>
                        <th class="text-end pe-4">Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ingreso in Model.DetalleIngresos)
                    {
                        <tr>
                            <td class="ps-4 text-muted small">@ingreso.Fecha.ToString("HH:mm")</td>
                            <td>
                                @if (ingreso.Socio != null)
                                {
                                    <span class="fw-bold text-dark d-block">@ingreso.Socio.ApellidoNombre</span>
                                    <small class="text-muted">ID: @ingreso.Socio.NumeroIdentificador</small>
                                }
                                else
                                {
                                    <span class="text-muted">No Socio / Externo</span>
                                }
                            </td>
                            <td>
                                @switch (ingreso.Tipo)
                                {
                                    case TipoIngreso.SocioAlDia: <span class="badge bg-success-subtle text-success rounded-pill px-3">Al Día</span> break;
                                    case TipoIngreso.SocioMoroso: <span class="badge bg-warning-subtle text-warning rounded-pill px-3">Moroso</span> break;
                                    case TipoIngreso.NoSocio: <span class="badge bg-dark-subtle text-dark rounded-pill px-3">Invitado</span> break;
                                }
                            </td>
                            <td class="text-end pe-4 fw-bold">@ingreso.MontoPagado.ToString("C0")</td>
                        </tr>
                    }
                    @if (!Model.DetalleIngresos.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted small">No hay ingresos registrados este día</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Desglose de Estacionamiento -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-0 d-flex align-items-center">
            <i class="fa-solid fa-parking text-primary me-2"></i>
            <h5 class="mb-0 fw-bold h6">Detalle de Estacionamiento</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small">
                    <tr>
                        <th class="ps-4">Hora</th>
                        <th>Tipo de Vehículo</th>
                        <th class="text-end pe-4">Monto</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var parking in Model.DetalleEstacionamiento)
                    {
                        <tr>
                            <td class="ps-4 text-muted small">@parking.Fecha.ToString("HH:mm")</td>
                            <td>
                                <span class="fw-bold text-dark">@parking.Vehiculo</span>
                            </td>
                            <td class="text-end pe-4 fw-bold">@parking.MontoPagado.ToString("C0")</td>
                        </tr>
                    }
                    @if (!Model.DetalleEstacionamiento.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted small">No hay cobros de estacionamiento este día</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4 text-center no-print">
        <a asp-action="Index" class="btn btn-light rounded-pill px-5 text-muted">VOLVER AL ESCÁNER</a>
    </div>
</div>

<style>
    @@media print {
        .no-print, .navbar, .sticky-top, header, footer {
            display: none !important;
        }
        .container {
            max-width: 100% !important;
            padding: 0 !important;
        }
        .card {
            box-shadow: none !important;
            border: 1px solid #eee !important;
        }
    }
</style>

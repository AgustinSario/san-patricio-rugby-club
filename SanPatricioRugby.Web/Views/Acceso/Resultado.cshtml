@model SanPatricioRugby.Web.Services.SocioStatusViewModel
@using SanPatricioRugby.DAL.Models

@{
    ViewData["Title"] = "Resultado de Búsqueda";
    var bgColor = Model.AlDia ? "bg-success" : (Model.Socio.EsActivo ? "bg-warning" : "bg-danger");
    var textColor = Model.AlDia ? "text-white" : "text-dark";
}

<div class="container py-4">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">
        <div class="card-body p-4 text-center @bgColor @textColor">
            <div class="avatar-lg bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                <span class="fs-1 fw-bold">@Model.Socio.ApellidoNombre.Substring(0, 1).ToUpper()</span>
            </div>
            <h2 class="h3 fw-bold mb-0">@Model.Socio.ApellidoNombre</h2>
            <p class="mb-1 opacity-75">DNI: @Model.Socio.Dni | @Model.Socio.Division</p>
            <div class="mt-3">
                @if (Model.AlDia)
                {
                    <span class="badge bg-white text-success px-4 py-2 rounded-pill fs-5">
                        <i class="fa-solid fa-circle-check me-2"></i> SOCIO AL DÍA
                    </span>
                    <h1 class="display-4 fw-black mt-3">PUEDE PASAR</h1>
                }
                else if (!Model.Socio.EsActivo)
                {
                    <span class="badge bg-white text-danger px-4 py-2 rounded-pill fs-5">
                        <i class="fa-solid fa-circle-xmark me-2"></i> SOCIO INACTIVO
                    </span>
                    <h1 class="display-4 fw-black mt-3">NO PASAR</h1>
                }
                else
                {
                    <span class="badge bg-white text-dark px-4 py-2 rounded-pill fs-5">
                        <i class="fa-solid fa-circle-exclamation me-2"></i> SOCIO MOROSO
                    </span>
                    <p class="mt-2 mb-0 fw-bold fs-5">Deuda: $ @Model.TotalDeuda.ToString("N0")</p>
                }
            </div>
        </div>
        
        @if (!Model.AlDia && Model.Socio.EsActivo)
        {
            <div class="card-body bg-light border-top">
                <h6 class="fw-bold text-muted mb-3">CUOTAS PENDIENTES</h6>
                <div class="list-group list-group-flush rounded-3 border">
                    @foreach (var cuota in Model.CuotasPendientes)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@cuota.Mes.ToString("00")/@cuota.Anio</span>
                            <span class="fw-bold text-danger">$ @cuota.Monto.ToString("N0")</span>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="card-footer bg-white p-4">
            <form asp-action="RegistrarIngreso" method="post" class="d-grid gap-3">
                <input type="hidden" name="socioId" value="@Model.Socio.Id" />
                
                @if (Model.AlDia)
                {
                    <input type="hidden" name="tipo" value="@TipoIngreso.SocioAlDia" />
                    <input type="hidden" name="monto" value="0" />
                    <button type="submit" class="btn btn-success btn-lg py-3 rounded-pill fw-bold shadow">
                        REGISTRAR INGRESO LIBRE
                    </button>
                }
                else
                {
                    <input type="hidden" name="tipo" value="@TipoIngreso.SocioMoroso" />
                    <input type="hidden" name="monto" value="@ViewBag.PrecioMoroso" />
                    <button type="submit" class="btn btn-warning btn-lg py-3 rounded-pill fw-bold shadow">
                        PAGAR ENTRADA MOROSO ($ @(((decimal)ViewBag.PrecioMoroso).ToString("N0")))
                    </button>
                    <a asp-controller="Cuotas" asp-action="Index" asp-route-searchString="@Model.Socio.ApellidoNombre" class="btn btn-outline-dark rounded-pill py-2">
                        Verificar Cuotas Detalladas
                    </a>
                }
                
                <a asp-action="Index" class="btn btn-light rounded-pill py-2 text-muted">VOLVER</a>
            </form>
        </div>
    </div>
</div>

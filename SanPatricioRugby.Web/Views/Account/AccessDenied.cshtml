@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="card-body">
                    <i class="fa-solid fa-hand-slash text-danger fs-1 mb-4"></i>
                    <h1 class="h3 fw-bold text-dark">Acceso Restringido</h1>
                    <p class="text-muted">Lo sentimos, no tienes los permisos necesarios para acceder a esta sección.</p>
                    <hr class="my-4 opacity-25">
                    <p class="small text-muted mb-4">Esta área está reservada para administradores del club.</p>
                    <a asp-controller="Acceso" asp-action="Index" class="btn btn-primary-color rounded-pill px-5">
                        IR AL CONTROL DE ACCESO
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

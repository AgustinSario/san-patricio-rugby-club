@using SanPatricioRugby.Web.Models
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="row justify-content-center">
    <div class="col-md-6 mt-4">
        <div class="card card-premium">
            <div class="card-body p-5">
                <h4 class="card-title fw-bold text-dark mb-4 text-center">@ViewData["Title"]</h4>
                
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="OldPassword" class="form-label text-muted fw-medium">Contraseña Actual</label>
                        <input asp-for="OldPassword" class="form-control form-control-lg bg-light" required>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NewPassword" class="form-label text-muted fw-medium">Nueva Contraseña</label>
                        <input asp-for="NewPassword" class="form-control form-control-lg bg-light" required>
                        <div class="form-text mt-1"><i class="fa-solid fa-circle-info me-1"></i>Debe contener al menos 6 caracteres, una mayúscula y un número.</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label text-muted fw-medium">Confirmar Nueva Contraseña</label>
                        <input asp-for="ConfirmPassword" class="form-control form-control-lg bg-light" required>
                    </div>

                    <div class="d-grid gap-2 mt-5">
                        <button type="submit" class="btn btn-primary bg-primary-color border-0 btn-lg shadow-sm">
                            <i class="fa-solid fa-save me-2"></i>Actualizar Contraseña
                        </button>
                        <a asp-action="Index" asp-controller="Dashboard" class="btn btn-light text-muted">Cancelar y Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

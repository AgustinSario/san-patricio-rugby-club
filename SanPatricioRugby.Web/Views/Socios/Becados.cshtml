@model SanPatricioRugby.Web.Models.PaginatedList<SanPatricioRugby.DAL.Models.Socio>

@{
    ViewData["Title"] = "Socios Becados";
}

<div class="container-fluid p-0">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-1 fw-bold text-dark">Socios Becados</h1>
                <p class="text-muted mb-0">Listado de socios con beneficios de beca activos.</p>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="ExportarBecadosPdf" class="btn btn-danger d-flex align-items-center shadow-sm">
                    <i class="fa-solid fa-file-pdf me-2"></i> Descargar PDF
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center shadow-sm">
                    <i class="fa-solid fa-arrow-left me-2"></i> Volver a Todos
                </a>
            </div>
        </div>
    </div>

    <!-- Search Section -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form asp-action="Becados" method="get" class="row g-3 align-items-end">
                <input type="hidden" name="pageNumber" value="1" />
                <div class="col-md-5">
                    <label class="form-label fw-semibold text-muted small">Buscar por Nombre</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 bg-light shadow-none" placeholder="Nombre..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold text-muted small">Buscar por DNI</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="fa-solid fa-id-card text-muted"></i></span>
                        <input type="text" name="searchDni" value="@ViewData["CurrentDni"]" class="form-control border-0 bg-light shadow-none" placeholder="DNI..." />
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark px-4 w-100 fw-bold">Filtrar</button>
                    <a asp-action="Becados" class="btn btn-light border px-3">
                        <i class="fa-solid fa-rotate-left"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 border-0">Nombre del Socio</th>
                            <th class="border-0">Tipo de Socio</th>
                            <th class="border-0">DNI</th>
                            <th class="border-0">Acuerdos / Beca</th>
                            <th class="border-0 text-end pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                        <span class="fw-bold">@item.ApellidoNombre.Substring(0, 1).ToUpper()</span>
                                    </div>
                                    <div>
                                        <p class="mb-0 fw-semibold text-dark">@item.ApellidoNombre</p>
                                        <small class="text-muted">ID: @item.NumeroIdentificador</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-primary bg-opacity-10 text-primary border-0 px-2 py-1">@item.TipoSocio</span>
                            </td>
                            <td>
                                <span class="text-muted">@item.Dni</span>
                            </td>
                            <td class="small text-muted">
                                @item.Acuerdos
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light border">
                                    <i class="fa-solid fa-eye text-primary"></i>
                                </a>
                            </td>
                        </tr>
                        }
                        @if (!Model.Any()) {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="fa-solid fa-graduation-cap fs-1 mb-3 d-block opacity-25"></i>
                                        <p>No se encontraron socios becados.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        
        @if (Model.TotalPages > 1) {
            <div class="card-footer bg-white py-3 border-top d-flex justify-content-between align-items-center px-4">
                <p class="text-muted mb-0 small">Página @Model.PageIndex de @Model.TotalPages</p>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link" asp-action="Becados" 
                               asp-route-pageNumber="@(Model.PageIndex - 1)" 
                               asp-route-searchString="@ViewData["CurrentFilter"]"
                               asp-route-searchDni="@ViewData["CurrentDni"]">
                                <i class="fa-solid fa-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++) {
                            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                                <a class="page-link" asp-action="Becados" asp-route-pageNumber="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link" asp-action="Becados" 
                               asp-route-pageNumber="@(Model.PageIndex + 1)"
                               asp-route-searchString="@ViewData["CurrentFilter"]"
                               asp-route-searchDni="@ViewData["CurrentDni"]">
                                <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
